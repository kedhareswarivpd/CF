# ==============================
# APP
# ==============================
ENV=development
APP_NAME=CoreFusion Technologies
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:5173
PORT=8000

# ==============================
# DATABASE
# Use Supabase's Postgres connection details here (Project Settings -> Database).
# For serverless/many short-lived connections use the "Transaction pooler" host
# and port 6543 with DB_USE_PGBOUNCER=true. For a long-running server like this
# one, the direct connection (port 5432) also works fine with DB_USE_PGBOUNCER=false.
# ==============================
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your-database-password
DB_USE_PGBOUNCER=false

# ==============================
# SUPABASE
# Project Settings -> API in the Supabase dashboard.
# NEVER expose SUPABASE_SERVICE_ROLE_KEY to a frontend/client app.
# ==============================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ==============================
# REDIS
# ==============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==============================
# JWT (algorithm used to verify Supabase-issued tokens)
# ==============================
JWT_ALGORITHM=HS256

# ==============================
# EMAIL (SMTP) - optional, only used for the contact-form notification email.
# Password reset / verification emails are sent by Supabase Auth itself.
# ==============================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CoreFusion Technologies <no-reply@corefusiontech.com>

# ==============================
# FILE UPLOADS
# ==============================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ==============================
# RATE LIMITING
# ==============================
RATE_LIMIT=300/15minute
